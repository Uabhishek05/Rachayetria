rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'admin' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          userDoc(request.auth.uid).data.role == 'admin'
        )
      );
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function ageAllowed(minAge) {
      return isSignedIn() && (
        minAge == 'under13' ||
        (minAge == 'teen' && userDoc(request.auth.uid).data.ageBracket in ['teen', 'adult']) ||
        (minAge == 'adult' && userDoc(request.auth.uid).data.ageBracket == 'adult')
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if isSignedIn() && ageAllowed(resource.data.ageRating);
      allow write: if isAdmin();

      match /chapters/{chapterId} {
        allow read: if isSignedIn() && ageAllowed(get(/databases/$(database)/documents/books/$(bookId)).data.ageRating);
        allow write: if isAdmin();
      }
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow write: if isAdmin();
    }

    match /discussions/{discussionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
  }
}
